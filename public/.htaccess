# the-good-foundry.com — Apache config
#
# SG handles HTTPS redirect and compression at the panel layer;
# this file focuses on URL hygiene + cache headers for static assets.

# Directory index — Apache's default looks for index.html / index.php.
# Our landing page is named the-good-foundry-index.html (kept the
# original WBM filename so internal nav doesn't churn), so tell
# Apache to use it as the directory index for / and any subdirectory
# request that hits a bare path.
DirectoryIndex the-good-foundry-index.html index.html index.htm

# Vanity URLs: /business-case → /business-case.html
# Means we don't have to hard-code .html suffixes in marketing links.
RewriteEngine On

# Skip the rewrite if the request maps to a real file/dir.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
# If <path>.html exists, serve it under the bare path.
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]

# Cache static assets aggressively — they're versioned by ?v= when
# they change. Browsers can hold them for a week.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png            "access plus 7 days"
  ExpiresByType image/jpeg           "access plus 7 days"
  ExpiresByType image/svg+xml        "access plus 7 days"
  ExpiresByType image/webp           "access plus 7 days"
  ExpiresByType image/x-icon         "access plus 30 days"
  ExpiresByType font/woff2           "access plus 30 days"
  ExpiresByType text/css             "access plus 1 day"
  ExpiresByType application/javascript "access plus 1 day"
  ExpiresByType text/html            "access plus 5 minutes"
</IfModule>

# Strip the trailing Server header noise (SG default leaves it noisy).
<IfModule mod_headers.c>
  Header unset X-Powered-By
  Header unset Server
</IfModule>
